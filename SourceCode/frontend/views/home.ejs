<%- include("layouts/header.ejs") -%>
    <div class="main">
      <div class="intro">
        <div class="intro-text">
          <h2>Be involved at U of R</h2>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Duis sed
            vestibulum dui, sit amet congue nisi. Nullam non mi a libero ornare
            pretium. Nullam fringilla et dui quis feugiat. Proin ullamcorper
            eros est, id luctus nisl pellentesque id. Etiam lobortis vitae augue
            a semper. Maecenas eget tempus leo.
          </p>
        </div>
        <img
          src="/images/pexels-ivan-s-5676744.jpg"
          alt="Bunch of students happily working together"
        />
      </div>
      <div>
        <h2>Clubs and Student Groups</h2>
        <div class="search-bar d-flex align-items-center">
          <i class="bi bi-search"></i>
          <input
            type="text"
            class="form-control border-0 shadow-none"
            placeholder="Type to search..."
          />
        </div>
      </div>
    </div>
    <div class="sort-card">
      <h4>Sort</h4>
      <ul class="list-group">
        <!-- Not sure how many options for sorting will be available but easily scalable -->
        <li>
          <input
            type="radio"
            name="sort"
            id="sort-by-name"
            class="form-check-input me-1"
            checked
          />
          <label for="sort-by-name" class="form-check-label">Name</label>
        </li>
        <li>
          <input
            type="radio"
            name="sort"
            id="sort-by-category"
            class="form-check-input me-1"
          />
          <label for="sort-by-category" class="form-check-label"
            >Category</label
          >
        </li>
        <li>
          <input
            type="radio"
            name="sort"
            id="sort-by-date"
            class="form-check-input me-1"
          />
          <label for="sort-by-date" class="form-check-label"
            >Date created</label
          >
        </li>
      </ul>
      <hr />
      <h4>Filter</h4>
      <!-- Same implementation as sort. Unsure what filter options available -->
    </div>
    <div class="club-group">
  <% if (clubs && clubs.length > 0) { %>
    <% clubs.forEach(club => { %>
      <div class="club-card">
          <a href="/clubs/<%= club._id %>" class="club-card-link">
            <img
              src="/images/University_of_Regina_Logo.jpg"
              alt="Club logo"
            />
            <p><%= club.name %></p>
            <small><%= club.category %></small>
          </a>
        </div>
    <% }) %>
  <% } else { %>
    <p>No clubs are available right now.</p>
  <% } %>
</div>
    <div class="call-to-action" id="first">
