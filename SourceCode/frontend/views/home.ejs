<%- include("layouts/header.ejs") -%>

<form id="searchSortFilterForm" action="/" method="GET" style="display: none;"></form>
    <div class="main">
      <div class="intro">
        <div class="intro-text">
          <h2>Be involved at the U of R</h2>
          <p>
            The University of Regina has many good clubs to join if you want to connect with other students over similar hobbies or interests.
            UR-Involved can help you find a club that suits you, and if you don't, you are one form away from making your own!
          </p>
        </div>
        <img
          src="/images/pexels-ivan-s-5676744.jpg"
          alt="Bunch of students happily working together"
        />
      </div>
      <div id="clubs-section">
        <h2>Clubs and Student Groups</h2>
        <div class="search-bar d-flex align-items-center">
          <i class="bi bi-search"></i>
          <!-- Search Input -->
          <input
            type="text"
            name="search"
            form="searchSortFilterForm"
            class="form-control border-0 shadow-none"
            placeholder="Search Clubs..."
            value="<%= currentSearch %>"
          />
        </div>
      </div>
    </div>
    <div class="sort-card">
      <h4>Sort</h4>
      <ul class="list-group">
        <!-- Sort Alphabetically -->
        <li>
          <input
            type="radio"
            name="sort"
            value="alphabetical"
            id="sort-alphabetically"
            form="searchSortFilterForm"
            class="form-check-input me-1"
            <% if (currentSort === 'alphabetical') { %>checked<% } %>
          />
          <label for="sort-alphabetically" class="form-check-label">Name A-Z</label>
        </li>
        <!-- Sort Reverse Alphabetically -->
        <li>
          <input
            type="radio"
            name="sort"
            value="reverseAlphabetical"
            id="sort-reverse-alphabetically"
            form="searchSortFilterForm"
            class="form-check-input me-1"
            <% if (currentSort === 'reverseAlphabetical') { %>checked<% } %>
          />
          <label for="sort-reverse-alphabetically" class="form-check-label">Name Z-A</label>
        </li>
        <!-- Sort by Newest -->
        <li>
          <input
            type="radio"
            name="sort"
            value="newest"
            id="sort-by-newest"
            form="searchSortFilterForm"
            class="form-check-input me-1"
            <% if (currentSort === 'newest') { %>checked<% } %>
          />
          <label for="sort-by-newest" class="form-check-label">Newest</label>
        </li>
        <!-- Sort by Oldest -->
        <li>
          <input
            type="radio"
            name="sort"
            value="oldest"
            id="sort-by-oldest"
            form="searchSortFilterForm"
            class="form-check-input me-1"
            <% if (currentSort === 'oldest') { %>checked<% } %>
          />
          <label for="sort-by-oldest" class="form-check-label">Oldest</label>
        </li>
      </ul>
      <hr />
      <h4>Filter</h4>
<ul class="list-group">
  <li>
    <input
      type="radio"
      name="filter"
      value="All"
      id="filter-all"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'All') { %>checked<% } %>
    />
    <label for="filter-all" class="form-check-label">All</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Science"
      id="filter-science"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Science') { %>checked<% } %>
    />
    <label for="filter-science" class="form-check-label">Science</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Humanities"
      id="filter-humanities"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Humanities') { %>checked<% } %>
    />
    <label for="filter-humanities" class="form-check-label">Humanities</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Engineering"
      id="filter-engineering"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Engineering') { %>checked<% } %>
    />
    <label for="filter-engineering" class="form-check-label">Engineering</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Sports"
      id="filter-sports"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Sports') { %>checked<% } %>
    />
    <label for="filter-sports" class="form-check-label">Sports</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Recreational"
      id="filter-recreational"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Recreational') { %>checked<% } %>
    />
    <label for="filter-recreational" class="form-check-label">Recreational</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Nursing"
      id="filter-nursing"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Nursing') { %>checked<% } %>
    />
    <label for="filter-nursing" class="form-check-label">Nursing</label>
  </li>

  <li>
    <input
      type="radio"
      name="filter"
      value="Business"
      id="filter-business"
      form="searchSortFilterForm"
      class="form-check-input me-1"
      <% if (currentFilter === 'Business') { %>checked<% } %>
    />
    <label for="filter-business" class="form-check-label">Business</label>
  </li>
</ul>
    </div>

    <div class="club-group" id="club-container">
      <%- include("partials/clubList.ejs", { clubs: clubs }) %>
    </div>
    
    <br>

    <div class="about-card">
    <div class="about-card-title">
      <p>About UR-Involved</p>
    </div>
    
           - Have you ever wanted to join a club, but felt it was too much of a pain to find the related information?
      <br> <br>
          - Have you ever had issues sharing important club information with members?
      <br> <br>
         These struggles were the motivation for the creation of UR-Involved. We believe that the effort you put into a club should be limited to the club activities, 
         not wasted on struggling to plan. UR-Involved lets clubs be easily made and applied to, so you can focus on what matters most.
    </div>


<script src="/js/filterClubs.js"></script>

<%- include("layouts/footer.ejs") -%>