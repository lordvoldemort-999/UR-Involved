<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UR Involved</title>

    <!-- Bootstrap CSS -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    />

    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    />

    <!-- Your CSS -->
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <header class="header header-main">

      <!-- LEFT: LOGO -->
      <div class="header-icon-container">
        <img src="/images/URegina_Coat_of_Arms.svg" alt="UR Icon" />
        <h2>UR Involved</h2>
      </div>

      <!-- CENTER: BACK BUTTON -->
      <div class="header-nav-main">
        <a href="/" class="btn btn-warning" role="button">
          Back to Homepage
        </a>
      </div>



      <!-- RIGHT: USER DROPDOWN -->
      <div class="dropdown dashboard-btn-container">
        <button class="btn dropdown-toggle bg-transparent border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" fill="rgba(224, 210, 14, 1)" class="bi bi-person-fill" viewBox="0 0 16 16">
            <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
          </svg>
        </button>
        <ul class="dropdown-menu">
          <label class="btn btn-warning" style="width: 158px; width: 192px; height: auto; text-align: center"> 
          <% if (currentUser) { %>
          <%- currentUser -%> 
          <% } else { %>
          Not logged in
          <% } %> 
          </label>
          <hr class="dropdown-divider">
          <li><form action="/dashboard" method="get" class="dropdown-item" style="height: 32px; text-align: center; margin: 0px;">
            <button class="bg-transparent border-0 "type="submit" style="width: 158px; height: auto; text-align: left">Dashboard</button>
          </form></li>
          <hr class="dropdown-divider">
          <li><form action="/logout" method="post" class="dropdown-item" style="height: 32px; text-align: center; margin: 0px;">
            <button class="bg-transparent border-0 "type="submit" style="width: 158px; height: auto; text-align: left">
              <% if (currentUser) { %>
                Logout</button>
              <% } else { %>
                Login</button>
              <% } %>
          </form></li>
        </ul>

      </div>

    </header>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>