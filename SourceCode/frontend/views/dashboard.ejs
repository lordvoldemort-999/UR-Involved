<%- include("layouts/secondary-header.ejs", { clubDetails: false, currentPage: "dashboard", currentUser: user.email }) -%>

<nav class="breadcrumb-container" aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/">Home</a></li>
    <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
  </ol>
</nav>

<div class="main">
  <h2>Welcome back, <%= user.email %></h2>

  <div class="profile-card mb-4">
    <div class="profile-left">
      <img
        src="<%= user.profilePicture || '/images/person-2-svgrepo-com.png' %>"
        alt="Your profile image"
        class="profile-image"
      />

      <form
        action="/account/delete"
        method="POST"
        onsubmit="return confirm('Are you sure you want to delete your account?');"
        style="margin-top: 8px; width: 100%;"
      >
        <button type="submit" class="btn btn-danger w-100">Delete Account</button>
      </form>
    </div>

    <div class="profile-info">
      <div class="header-row">
        <h2>Your profile</h2>
      </div>

      <h3><%= user.email %></h3>
      <p>Role: <%= user.role %></p>

      <form
        action="/profile/upload"
        method="POST"
        enctype="multipart/form-data"
        class="mb-3"
        style="margin-top: 15px;"
      >
        <label for="newProfileImage" class="form-label">Change profile picture</label>
        <input
          type="file"
          name="profileImage"
          id="newProfileImage"
          class="form-control mb-2"
          accept=".png,.jpg,.jpeg,.gif,.webp"
          required
        />
        <button type="submit" class="btn btn-success">Upload New Picture</button>
      </form>
    </div>
  </div>

  <% if (isSystemAdminDashboard) { %>
    <div class="tabs">
      <button class="tab active" onclick="showDashboardTab('admin-requests', this)">Club Creation Requests</button>
      <button class="tab" onclick="showDashboardTab('admin-users', this)">Users</button>
    </div>

    <div id="admin-requests" class="tab-content active">
      <h2>Club creation requests</h2>
      <div class="club-container mb-4">
        <% if (clubRequests && clubRequests.length > 0) { %>
          <% clubRequests.forEach(request => { %>
            <div
              class="dashboard-club-card"
              style="width: 100%; height: auto; text-align: left; align-items: flex-start;"
            >
              <img src="<%= request.logo %>" alt="Club logo" />

              <p><strong>Proposed name:</strong> <%= request.proposedName %></p>
              <p><strong>Description:</strong> <%= request.description %></p>
              <p><strong>Category:</strong> <%= request.category %></p>
              <p><strong>Contact email:</strong> <%= request.contactEmail %></p>
              <p><strong>Website:</strong> <%= request.website || "None provided" %></p>
              <p>
                <strong>Submitted by:</strong>
                <%= request.requestedBy ? request.requestedBy.email : "Unknown user" %>
              </p>
              <small>Status: <%= request.status %></small>

              <div style="display: flex; gap: 10px; margin-top: 15px; flex-wrap: wrap;">
                <form action="/admin/club-requests/<%= request._id %>/approve" method="POST">
                  <button type="submit" class="btn btn-success">Approve</button>
                </form>

                <form action="/admin/club-requests/<%= request._id %>/reject" method="POST">
                  <button type="submit" class="btn btn-danger">Reject</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <p>No club creation requests found.</p>
        <% } %>
      </div>
    </div>

    <div id="admin-users" class="tab-content">
      <h2>Users</h2>
      <div class="club-container mb-4">
        <% if (allUsers && allUsers.length > 0) { %>
          <% allUsers.forEach(account => { %>
            <div
              class="dashboard-club-card"
              style="width: 100%; height: auto; text-align: left; align-items: flex-start;"
            >
              <img
                src="<%= account.profilePicture || '/images/University_of_Regina_Logo.jpg' %>"
                alt="User profile picture"
              />

              <p><strong>Email:</strong> <%= account.email %></p>
              <p><strong>Role:</strong> <%= account.role %></p>

              <form
                action="/admin/users/<%= account._id %>/delete"
                method="POST"
                onsubmit="return confirm('Are you sure you want to delete this user account?');"
                style="margin-top: 15px;"
              >
                <button type="submit" class="btn btn-danger">Delete User</button>
              </form>
            </div>
          <% }) %>
        <% } else { %>
          <p>No users found.</p>
        <% } %>
      </div>
    </div>

  <% } else { %>
    <div class="tabs">
      <button class="tab active" onclick="showDashboardTab('student-clubs', this)">Your Clubs</button>
      <button class="tab" onclick="showDashboardTab('student-join-requests', this)">Your Join Requests</button>
      <button class="tab" onclick="showDashboardTab('student-creation-requests', this)">Your Club Creation Requests</button>
    </div>

    <div id="student-clubs" class="tab-content active">
      <h2>Your clubs</h2>
      <div class="club-container">
        <% if (memberClubs && memberClubs.length > 0) { %>
          <% memberClubs.forEach(club => { %>
            <div class="dashboard-club-card">
              <a href="/clubs/<%= club._id %>" class="club-card-link">
                <img src="<%= club.logo %>" alt="Club logo" />
                <p><%= club.name %></p>

                <% if (club.createdBy && club.createdBy.toString() === user._id.toString()) { %>
                  <small>Club Creator</small>
                <% } else if (club.admins && club.admins.some(adminId => adminId.toString() === user._id.toString())) { %>
                  <small>Admin</small>
                <% } else { %>
                  <small>Member</small>
                <% } %>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <p>You are not a member of any clubs yet.</p>
        <% } %>
      </div>
    </div>

    <div id="student-join-requests" class="tab-content">
      <h2>Your join requests</h2>
      <div class="club-container mb-4">
        <% if (userJoinRequests && userJoinRequests.length > 0) { %>
          <% userJoinRequests.forEach(request => { %>
            <div class="dashboard-club-card">
              <a href="/clubs/<%= request.club._id %>" class="club-card-link">
                <img src="<%= request.club.logo %>" alt="Club logo" />
                <p><%= request.club.name %></p>
                <small>Status: <%= request.status %></small>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <p>You have not sent any join requests yet.</p>
        <% } %>
      </div>
    </div>

    <div id="student-creation-requests" class="tab-content">
      <h2>Your club creation requests</h2>
      <div class="club-container mb-4">
        <% if (userClubCreationRequests && userClubCreationRequests.length > 0) { %>
          <% userClubCreationRequests.forEach(request => { %>
            <div class="dashboard-club-card">
              <a href="#" class="club-card-link">
                <img src="<%= request.logo %>" alt="Club logo" />
                <p><%= request.proposedName %></p>
                <small>Status: <%= request.status %></small>
              </a>
            </div>
          <% }) %>
        <% } else { %>
          <p>You have not submitted any club creation requests yet.</p>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<%- include("layouts/footer.ejs") -%>

<script>
  function showDashboardTab(tabId, btn) {
    document.querySelectorAll('.tab-content').forEach(tab => {
      tab.classList.remove('active');
    });

    document.querySelectorAll('.tab').forEach(tab => {
      tab.classList.remove('active');
    });

    document.getElementById(tabId).classList.add('active');
    btn.classList.add('active');
  }
</script>