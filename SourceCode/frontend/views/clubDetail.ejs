<div class="club-detail-page">

  <%- include("layouts/secondary-header") -%>

  <!-- SUCCESS MESSAGE -->
  <% if (joined === "true") { %>
    <div style="
      background: #e6f9f0;
      color: #0c6b58;
      padding: 12px;
      margin: 20px;
      border-radius: 10px;
      font-weight: 500;
      text-align: center;
    ">
      Request sent successfully!
    </div>
  <% } %>

  <% if (!club) { %>
    <p style="padding:40px;">Club not found</p>
  <% } else { %>

  <div class="main">
    <div class="club-content">

      <!-- LEFT SIDE -->
      <div class="club-card">

        <div class="club-logo"></div>

        <h3 class="club-name"><%= club.name %></h3>

        <p class="club-description">
          <%= club.description || "No description available." %>
        </p>

        <p class="created-date">
          Created:
          <%= club.createdAt 
            ? new Date(club.createdAt).toLocaleDateString() 
            : "N/A" %>
        </p>

        <!-- BUTTONS -->
        <div class="club-actions">

          <% if (joined === "true") { %>
            <button class="join-btn" disabled style="background: grey;">
              Request Sent
            </button>
          <% } else { %>
            <a href="/clubs/<%= club._id %>/join" class="join-btn">
              Request to Join
            </a>
          <% } %>

          <% if (club.contactEmail) { %>
            <a href="mailto:<%= club.contactEmail %>" class="contact-btn">
              Contact
            </a>
          <% } %>

        </div>

        <!-- EMAIL -->
        <% if (club.contactEmail) { %>
          <p class="contact-email">
            <%= club.contactEmail %>
          </p>
        <% } %>

      </div>

      <!-- RIGHT SIDE -->
      <div class="events-area">

        <!-- UPCOMING EVENTS -->
        <h2 class="section-title">Upcoming events</h2>

        <div class="event-grid">
          <% if (upcoming && upcoming.length > 0) { %>
            <% upcoming.forEach(event => { %>
              <div class="event-card">
                <div class="event-image"></div>
                <div class="event-info">
                  <h4><%= event.title %></h4>
                  <p><%= event.location || "No location" %></p>
                  <p><%= new Date(event.date).toLocaleDateString() %></p>
                  <p><%= event.price ? "$" + event.price : "Free" %></p>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="no-events">No upcoming events</p>
          <% } %>
        </div>

        <!-- PAST EVENTS -->
        <h2 class="section-title">Past events</h2>

        <div class="event-grid">
          <% if (past && past.length > 0) { %>
            <% past.forEach(event => { %>
              <div class="event-card">
                <div class="event-image"></div>
                <div class="event-info">
                  <h4><%= event.title %></h4>
                  <p><%= event.location || "No location" %></p>
                  <p><%= new Date(event.date).toLocaleDateString() %></p>
                  <p><%= event.price ? "$" + event.price : "Free" %></p>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="no-events">No past events</p>
          <% } %>
        </div>

      </div>

    </div>
  </div>

  <% } %>

  <%- include("layouts/footer") -%>

</div>