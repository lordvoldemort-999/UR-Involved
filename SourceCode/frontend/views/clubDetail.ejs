<%- include("layouts/secondary-header") -%>

<div class="club-detail-page">

  <% if (existingJoinRequest && existingJoinRequest.status === "pending") { %>
  <div class="alert warning">
    Your join request is pending.
  </div>
<% } else if (existingJoinRequest && existingJoinRequest.status === "rejected") { %>
  <div class="alert warning">
    Your join request was rejected.
  </div>
<% } %>

  <% if (!club) { %>
    <p style="padding:40px;">Club not found</p>
  <% } else { %>

  <div class="main">
    <div class="club-content">

      <div class="club-card">

        <% if (club.logo) { %>
          <img src="<%= club.logo %>" class="club-logo-img" alt="<%= club.name %> logo" />
        <% } else { %>
          <img src="/images/URegina_Coat_of_Arms.svg" class="club-logo-img" alt="Default club logo" />
        <% } %>

        <h3 class="club-name"><%= club.name %></h3>

        <p class="club-created-date">
          Created:
          <%= club.createdAt
            ? new Date(club.createdAt).toLocaleDateString()
            : "N/A" %>
        </p>

        <div class="club-actions">

          <% if (!currentUser || currentUser.role !== "systemAdmin") { %>
            <% if (alreadyMember) { %>
              <button class="join-btn" disabled>Club Member</button>

            <% } else if (existingJoinRequest && existingJoinRequest.status === "pending") { %>
              <button class="join-btn" disabled>Pending</button>

            <% } else if (existingJoinRequest && existingJoinRequest.status === "rejected") { %>
              <button class="join-btn" disabled>Rejected</button>

            <% } else { %>
              <form action="/clubs/<%= club._id %>/join" method="POST" style="display:inline;">
                <button type="submit" class="join-btn">Request to Join</button>
              </form>
            <% } %>
          <% } %>

          <% if (club.contactEmail) { %>
            <a href="mailto:<%= club.contactEmail %>" class="contact-btn">
              Contact
            </a>
          <% } %>

          <% if (club.website) { %>
            <a href="<%= club.website %>" target="_blank" class="contact-btn">
              Website
            </a>
          <% } %>

        </div>

        <% if (club.contactEmail) { %>
          <p class="contact-email"><%= club.contactEmail %></p>
        <% } %>

        <% if (currentUser && (
          currentUser.role === "systemAdmin" ||
          (club.createdBy && club.createdBy.toString() === currentUser._id.toString())
        )) { %>
          <form action="/clubs/<%= club._id %>/delete" method="POST" style="margin-top: 15px;">
            <button
              type="submit"
              class="btn btn-danger"
              onclick="return confirm('Are you sure you want to delete this club?');"
            >
              Delete Club
            </button>
          </form>
        <% } %>

      </div>

      <div class="right-content">

        <div class="tabs">
          <button class="tab" onclick="showTab('about', this)">About</button>
          <button class="tab active" onclick="showTab('events', this)">Events</button>
          <button class="tab" onclick="showTab('members', this)">Members</button>
          <% if (currentUser && (
            currentUser.role === "systemAdmin" ||
            (club.createdBy && club.createdBy.toString() === currentUser._id.toString())
          )) { %>
            <button class="tab" onclick="showTab('joinRequests', this)">Join Requests</button>
          <% } %>
        </div>

        <div id="events" class="tab-content active">

          <h3>Upcoming Events</h3>

          <% if (upcoming && upcoming.length > 0) { %>
            <div class="event-grid">
              <% upcoming.forEach(event => { %>
                <div class="event-card">
                  <h4><%= event.title %></h4>
                  <p><%= event.location || "No location" %></p>
                  <p><%= new Date(event.date).toLocaleDateString() %></p>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p>No upcoming events</p>
          <% } %>

          <h3 style="margin-top:30px;">Past Events</h3>

          <% if (past && past.length > 0) { %>
            <div class="event-grid">
              <% past.forEach(event => { %>
                <div class="event-card">
                  <h4><%= event.title %></h4>
                  <p><%= event.location || "No location" %></p>
                  <p><%= new Date(event.date).toLocaleDateString() %></p>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p>No past events</p>
          <% } %>

        </div>

        <div id="about" class="tab-content">

          <div class="empty-box">
            <h4>About</h4>
            <p><%= club.description || "No description available." %></p>
          </div>

          <div class="empty-box" style="margin-top: 20px;">
            <h4>Category</h4>
            <p><%= club.category || "Not specified" %></p>
          </div>

        </div>

        <div id="members" class="tab-content">
          <div class="empty-box">
            <p>Nothing to see (yet!)</p>
          </div>
        </div>

        <div id="joinRequests" class="tab-content">
          <% if (currentUser && (
            currentUser.role === "systemAdmin" ||
            (club.createdBy && club.createdBy.toString() === currentUser._id.toString())
          )) { %>
            <div class="empty-box" style="align-items: flex-start; text-align: left; max-width: 100%;">
              <h3 style="color: #00c800; margin-bottom: 20px;">Pending Join Requests</h3>

              <% if (typeof joinRequests !== 'undefined' && joinRequests && joinRequests.length > 0) { %>
                <ul class="request-list" style="list-style: none; padding: 0; width: 100%;">
                  <% joinRequests.forEach(request => { %>
                    <li class="request-item" style="background: #ffffff; padding: 15px; border-radius: 12px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; border: 1px solid #ddd;">
                      <span class="username"><strong><%= request.student ? request.student.email : "Unknown User" %></strong></span>
                      <div class="actions" style="display: flex; gap: 10px;">
                        <form action="/admin/join-requests/<%= request._id %>/approve" method="POST" style="margin: 0;">
                          <button type="submit" class="join-submit-btn" style="padding: 8px 16px; font-size: 0.9rem;">Accept</button>
                        </form>
                        <form action="/admin/join-requests/<%= request._id %>/reject" method="POST" style="margin: 0;">
                          <button type="submit" style="padding: 8px 16px; font-size: 0.9rem; background-color: #dc3545; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 500;">Decline</button>
                        </form>
                      </div>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p>There are currently no join requests.</p>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>

  <% } %>

</div>

<%- include("layouts/footer") -%>

<script>
function showTab(tabId, btn) {
  document.querySelectorAll('.tab-content').forEach(tab => {
    tab.classList.remove('active');
  });

  document.querySelectorAll('.tab').forEach(tab => {
    tab.classList.remove('active');
  });

  document.getElementById(tabId).classList.add('active');
  btn.classList.add('active');
}
</script>